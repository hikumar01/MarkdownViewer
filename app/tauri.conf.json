{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkdownViewer",
  "version": "0.1.0",
  "identifier": "com.markdownviewer.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:frontend",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MarkdownViewer",
        "width": 960,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' markdownviewer: data: blob: https:; connect-src ipc: http://ipc.localhost; font-src 'self' data: https:; worker-src blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown File",
        "role": "Viewer",
        "mimeType": "text/markdown"
      }
    ]
  }
}
